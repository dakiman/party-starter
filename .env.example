# Database
# - For host-JVM dev (./mvnw spring-boot:run after `docker compose up -d mysql`): use localhost:3308 (the loopback port mapping in docker-compose.yml).
# - For containerized run (`docker compose up -d`): docker-compose's `environment:` block overrides DB_HOST to mysql:3306 (the bridge-network address). The value here doesn't matter in that case.
DB_HOST=localhost:3308
DB_NAME=spring_app
DB_USERNAME=root
DB_PASSWORD=changeme

# Auth
# JWT_SECRET is REQUIRED — no default. Boot fails fast if missing or shorter than 32 chars.
JWT_SECRET=changeme-prod-set-something-long-at-least-32-chars
JWT_ISSUER=PartyStarterInc

# CORS — comma-separated list of allowed origins. Default covers the FE in
# both Vite dev (5173) and the dakis-server nginx container (8094).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8094

# Background seeding job (off by default; flip to true the first time you bring up an empty DB)
SHOULD_SEED=false
COCKTAIL_DB_API_KEY=1

# Spotify
# Public client-id (Phase 1 moved this from a hardcoded application.yml value to env).
SPOTIFY_CLIENT_ID=d0982bc6c139493bbe74eee8d2ddd811
SPOTIFY_SECRET=changeme

# Logging
LOGGING_LEVEL=info

# Host port to expose the Spring app on (consumed by docker-compose's port mapping)
APP_PORT=8093

# Phase 3 sharing — base URL the FE is served from. Used to compose share links.
# In dakis-server compose, this is the public-facing FE URL; for local dev, the Vite or nginx host.
FRONTEND_BASE_URL=http://localhost:8094
